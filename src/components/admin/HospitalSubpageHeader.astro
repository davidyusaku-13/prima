---
import AdminBadge from "./AdminBadge.astro";

type HospitalTab = "overview" | "users" | "invites";

type HeaderStat = {
    label: string;
    value: string;
};

type Props = {
    slug: string;
    label?: string;
    activeTab: HospitalTab;
    isActive?: boolean;
    stats?: HeaderStat[];
};

const { slug, label = slug, activeTab, isActive = true, stats = [] } = Astro.props as Props;
const hasActions = Astro.slots.has("actions");

const tabs: Array<{ key: HospitalTab; href: string; label: string }> = [
    { key: "overview", href: `/admin/hospitals/${slug}`, label: "Overview" },
    { key: "users", href: `/admin/hospitals/${slug}/users`, label: "Users" },
    { key: "invites", href: `/admin/hospitals/${slug}/invites`, label: "Invite Links" },
];
---

<header class="hospital-header">
    <div class="meta-row">
        <p class="breadcrumbs">
            <a href="/admin">Admin</a>
            <span>/</span>
            <a href="/admin/hospitals">Hospitals</a>
            <span>/</span>
            <span class="current">{label}</span>
        </p>

        {
            hasActions && (
                <div class="header-actions">
                    <slot name="actions" />
                </div>
            )
        }
    </div>

    <div class="title-row">
        <div class="title-stack">
            <h1>{label}</h1>
            <p class="slug">/{slug}</p>
        </div>
        <AdminBadge label={isActive ? "Active" : "Inactive"} tone={isActive ? "success" : "danger"} />
    </div>

    <nav class="tabs" aria-label="Hospital sections">
        {
            tabs.map((tab) => (
                <a
                    href={tab.href}
                    class:list={["tab-link", { "is-active": activeTab === tab.key }]}
                    aria-current={activeTab === tab.key ? "page" : undefined}
                >
                    {tab.label}
                </a>
            ))
        }
    </nav>

    {
        stats.length > 0 && (
            <ul class="stats-grid" aria-label="Hospital summary">
                {
                    stats.map((stat) => (
                        <li>
                            <span class="stat-label">{stat.label}</span>
                            <strong>{stat.value}</strong>
                        </li>
                    ))
                }
            </ul>
        )
    }
</header>

<style>
    .hospital-header {
        display: grid;
        gap: 0.7rem;
    }

    .meta-row {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .breadcrumbs {
        margin: 0;
        font-size: 0.86rem;
        color: #607089;
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        align-items: center;
    }

    .breadcrumbs a {
        color: #285792;
        text-decoration: none;
    }

    .breadcrumbs a:hover {
        text-decoration: underline;
    }

    .current {
        color: #1f365b;
        font-weight: 600;
    }

    .title-row {
        display: flex;
        justify-content: space-between;
        gap: 0.65rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .title-stack {
        display: flex;
        gap: 0.45rem;
        align-items: baseline;
        flex-wrap: wrap;
    }

    h1 {
        margin: 0;
    }

    .slug {
        margin: 0;
        color: #516178;
        font-size: 0.9rem;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }

    .header-actions {
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
    }

    .tabs {
        display: flex;
        gap: 0.55rem;
        flex-wrap: wrap;
    }

    .tab-link {
        text-decoration: none;
        border: 1px solid #c5d6f2;
        border-radius: 999px;
        padding: 0.35rem 0.75rem;
        color: #1f365b;
        background: #f7faff;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition:
            background-color 180ms ease,
            border-color 180ms ease,
            color 180ms ease;
    }

    .tab-link:hover {
        background: #eef4ff;
        border-color: #b8cdf0;
    }

    .tab-link.is-active {
        background: #1f66d2;
        border-color: #1f66d2;
        color: #ffffff;
    }

    .stats-grid {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
        gap: 0.55rem;
    }

    .stats-grid li {
        border: 1px solid #dce6f7;
        border-radius: 10px;
        padding: 0.5rem 0.6rem;
        background: #f8fbff;
        display: grid;
        gap: 0.2rem;
    }

    .stat-label {
        font-size: 0.77rem;
        color: #607089;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .stats-grid strong {
        color: #1f365b;
    }
</style>
