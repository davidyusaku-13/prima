---
import Layout from "../../../layouts/Layout.astro";
import AdminBadge from "../../../components/admin/AdminBadge.astro";
import HospitalSubpageHeader from "../../../components/admin/HospitalSubpageHeader.astro";
import { fetchAdminJson } from "../../../utils/admin-api";

const API_URL = Astro.locals.apiUrl;
const token = Astro.locals.authToken;
const slug = String(Astro.params.slug ?? "").trim();

type AdminProbe = {
    role: string;
    hospital_id: number;
};

type Hospital = {
    id: number;
    name: string;
    slug: string;
    is_active: boolean;
    created_at: string;
};

type HospitalUser = {
    clerk_id: string;
};

type HospitalInvite = {
    id: number;
    expires_at: string;
    consumed_at: string | null;
};

type HospitalAdmin = {
    clerk_id: string;
    name: string;
    email: string;
    username: string;
    assigned_at: string;
};

type AdminCandidate = {
    clerk_id: string;
    name: string;
    email: string;
    username: string;
    role: string;
    is_active: boolean;
    membership_hospital_id: number;
    membership_hospital_slug: string;
    membership_role: string;
    assignable: boolean;
    status: "unassigned" | "member" | "already_admin" | "assigned_elsewhere";
};

const fallbackProbe: AdminProbe = {
    role: "",
    hospital_id: 0,
};
const fallbackHospitals: Hospital[] = [];
const fallbackUsers: HospitalUser[] = [];
const fallbackInvites: HospitalInvite[] = [];
const fallbackAdmins: HospitalAdmin[] = [];
const fallbackCandidates: AdminCandidate[] = [];

const candidateStatusLabel: Record<AdminCandidate["status"], string> = {
    unassigned: "Unassigned",
    member: "Member",
    already_admin: "Already Admin",
    assigned_elsewhere: "Assigned Elsewhere",
};

const candidateStatusTone: Record<AdminCandidate["status"], "success" | "info" | "warning" | "danger"> = {
    unassigned: "success",
    member: "info",
    already_admin: "warning",
    assigned_elsewhere: "danger",
};

let actionResult = "";
let actionError = "";

if (Astro.request.method === "POST") {
    if (!token) {
        return Astro.redirect("/");
    }

    const formData = await Astro.request.formData();
    const action = String(formData.get("_action") ?? "").trim();
    const userClerkID = String(formData.get("user_clerk_id") ?? "").trim();

    if (!action || !userClerkID) {
        actionError = "Action and user identifier are required.";
    } else {
        const endpoint = `${API_URL}/admin/hospitals/${encodeURIComponent(slug)}/admins`;
        const response =
            action === "assign"
                ? await fetch(endpoint, {
                        method: "POST",
                        headers: {
                            Authorization: `Bearer ${token}`,
                            "Content-Type": "application/json",
                        },
                        body: JSON.stringify({ user_clerk_id: userClerkID }),
                    }).catch(() => null)
                : action === "remove"
                  ? await fetch(`${endpoint}/${encodeURIComponent(userClerkID)}`, {
                        method: "DELETE",
                        headers: {
                            Authorization: `Bearer ${token}`,
                        },
                    }).catch(() => null)
                  : null;

        if (!response) {
            actionError = "Request failed. Please try again.";
        } else if (response.status === 401 || response.status === 403) {
            return Astro.redirect("/");
        } else if (response.ok) {
            actionResult =
                action === "assign"
                    ? "Representative assigned successfully."
                    : "Representative removed successfully.";
        } else {
            const payload = (await response.json().catch(() => null)) as { error?: string } | null;
            actionError = payload?.error ?? "Representative action failed.";
        }
    }
}

const probeResult = await fetchAdminJson(token, "/admin", fallbackProbe, API_URL);
if (probeResult.unauthorized) {
    return Astro.redirect("/");
}
const adminInfo = probeResult.data;
const isSuperadmin = adminInfo.role === "superadmin";

const hospitalsResult = await fetchAdminJson(token, "/admin/hospitals", fallbackHospitals, API_URL);
if (hospitalsResult.unauthorized) {
    return Astro.redirect("/");
}
const hospital = hospitalsResult.data.find((entry) => entry.slug === slug);
if (!hospital) {
    return Astro.redirect("/admin/hospitals");
}

const usersResult = await fetchAdminJson(
    token,
    `/admin/hospitals/${encodeURIComponent(slug)}/users`,
    fallbackUsers,
    API_URL,
);
if (usersResult.unauthorized) {
    return Astro.redirect("/");
}

const invitesResult = await fetchAdminJson(
    token,
    `/admin/hospitals/${encodeURIComponent(slug)}/invites`,
    fallbackInvites,
    API_URL,
);
if (invitesResult.unauthorized) {
    return Astro.redirect("/");
}

let hospitalAdmins = fallbackAdmins;
let adminCandidates = fallbackCandidates;
if (isSuperadmin) {
    const adminsResult = await fetchAdminJson(
        token,
        `/admin/hospitals/${encodeURIComponent(slug)}/admins`,
        fallbackAdmins,
        API_URL,
    );
    if (adminsResult.unauthorized) {
        return Astro.redirect("/");
    }
    hospitalAdmins = adminsResult.data;

    const candidatesResult = await fetchAdminJson(
        token,
        `/admin/hospitals/${encodeURIComponent(slug)}/admin-candidates`,
        fallbackCandidates,
        API_URL,
    );
    if (candidatesResult.unauthorized) {
        return Astro.redirect("/");
    }
    adminCandidates = candidatesResult.data;
}

const now = Date.now();
const activeInviteCount = invitesResult.data.filter((invite) => {
    if (invite.consumed_at) {
        return false;
    }
    const expiresAt = new Date(invite.expires_at).getTime();
    return Number.isFinite(expiresAt) && expiresAt > now;
}).length;
const usedInviteCount = invitesResult.data.filter((invite) => Boolean(invite.consumed_at)).length;

const headerStats = [
    { label: "Users", value: String(usersResult.data.length) },
    { label: "Representatives", value: String(hospitalAdmins.length) },
    { label: "Active Invites", value: String(activeInviteCount) },
    { label: "Used Invites", value: String(usedInviteCount) },
];
---

<Layout title={`Hospital ${hospital.name}`}>
    <section class="panel workspace">
        <HospitalSubpageHeader
            slug={hospital.slug}
            label={hospital.name}
            activeTab="overview"
            isActive={hospital.is_active}
            stats={headerStats}
        >
            <div slot="actions" class="header-actions">
                <a href={`/admin/hospitals/${hospital.slug}/users`} class="quick-action">Users</a>
                <a href={`/admin/hospitals/${hospital.slug}/invites`} class="quick-action">Invite Links</a>
            </div>
        </HospitalSubpageHeader>

        {actionResult && (
            <p class="message" role="status">
                {actionResult}
            </p>
        )}
        {actionError && (
            <p class="message error" role="alert">
                {actionError}
            </p>
        )}

        {
            isSuperadmin ? (
                <div class="split-layout">
                    <section class="content-panel" aria-labelledby="representatives-heading">
                        <div class="section-head">
                            <h2 id="representatives-heading">Current Representatives</h2>
                            <AdminBadge
                                label={`${hospitalAdmins.length} assigned`}
                                tone="info"
                                showDot={false}
                            />
                        </div>

                        {hospitalAdmins.length === 0 ? (
                            <p class="subtle">No representatives assigned yet.</p>
                        ) : (
                            <ul class="data-list">
                                {
                                    hospitalAdmins.map((admin) => (
                                        <li>
                                            <div class="identity">
                                                <strong>{admin.name}</strong>
                                                {admin.email && <span class="subtle">&lt;{admin.email}&gt;</span>}
                                                {admin.username && <span class="subtle">@{admin.username}</span>}
                                            </div>
                                            <form
                                                method="post"
                                                data-pending-label="Removing..."
                                                data-confirm="Remove this representative from this hospital?"
                                            >
                                                <input type="hidden" name="_action" value="remove" />
                                                <input type="hidden" name="user_clerk_id" value={admin.clerk_id} />
                                                <button type="submit" class="danger">Remove</button>
                                            </form>
                                        </li>
                                    ))
                                }
                            </ul>
                        )}
                    </section>

                    <section class="content-panel" aria-labelledby="assign-heading">
                        <div class="section-head">
                            <h2 id="assign-heading">Assign Representatives</h2>
                            <AdminBadge
                                label={`${adminCandidates.filter((candidate) => candidate.assignable).length} assignable`}
                                tone="success"
                                showDot={false}
                            />
                        </div>

                        {adminCandidates.length === 0 ? (
                            <p class="subtle">No candidates found.</p>
                        ) : (
                            <ul class="data-list">
                                {
                                    adminCandidates.map((candidate) => (
                                        <li>
                                            <div class="identity">
                                                <strong>{candidate.name}</strong>
                                                {candidate.email && <span class="subtle">&lt;{candidate.email}&gt;</span>}
                                                {candidate.username && <span class="subtle">@{candidate.username}</span>}
                                                <AdminBadge
                                                    label={
                                                        candidate.status === "assigned_elsewhere"
                                                            ? `Assigned to ${
                                                                  candidate.membership_hospital_slug ||
                                                                  "another hospital"
                                                              }`
                                                            : candidateStatusLabel[candidate.status]
                                                    }
                                                    tone={candidateStatusTone[candidate.status]}
                                                />
                                            </div>
                                            <form method="post" data-pending-label="Assigning...">
                                                <input type="hidden" name="_action" value="assign" />
                                                <input
                                                    type="hidden"
                                                    name="user_clerk_id"
                                                    value={candidate.clerk_id}
                                                />
                                                <button type="submit" disabled={!candidate.assignable}>
                                                    Assign
                                                </button>
                                            </form>
                                        </li>
                                    ))
                                }
                            </ul>
                        )}
                    </section>
                </div>
            ) : (
                <section class="content-panel" aria-labelledby="overview-note-heading">
                    <h2 id="overview-note-heading">Representative management is limited to superadmins.</h2>
                    <p class="subtle">
                        You can still view hospital users and invite links through the tabs above.
                    </p>
                </section>
            )
        }
    </section>
</Layout>

<script is:inline>
    (() => {
        const actionForms = document.querySelectorAll("form[data-pending-label]");
        for (const form of actionForms) {
            form.addEventListener("submit", (event) => {
                const confirmText = form.getAttribute("data-confirm");
                if (confirmText && !window.confirm(confirmText)) {
                    event.preventDefault();
                    return;
                }

                const submitter = event.submitter instanceof HTMLElement ? event.submitter : null;
                const button =
                    submitter?.tagName === "BUTTON"
                        ? submitter
                        : form.querySelector("button[type='submit']");
                if (!button || button.disabled) {
                    return;
                }

                const pendingLabel = form.getAttribute("data-pending-label") ?? "Saving...";
                button.setAttribute("aria-busy", "true");
                button.textContent = pendingLabel;
                button.disabled = true;
            });
        }
    })();
</script>

<style>
    .panel {
        background: #ffffff;
        border: 1px solid #dce6f7;
        border-radius: 16px;
        padding: clamp(1rem, 2.5vw, 1.5rem);
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    }

    .workspace {
        display: grid;
        gap: 0.9rem;
    }

    .header-actions {
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
    }

    .quick-action {
        text-decoration: none;
        border: 1px solid #bdd2f2;
        border-radius: 999px;
        padding: 0.3rem 0.72rem;
        color: #1f4f95;
        font-weight: 600;
        font-size: 0.84rem;
        transition:
            background-color 180ms ease,
            border-color 180ms ease;
    }

    .quick-action:hover {
        background: #edf4ff;
        border-color: #9ebde8;
    }

    .message {
        margin: 0;
        color: #1f365b;
    }

    .message.error {
        color: #991b1b;
    }

    .split-layout {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
    }

    .content-panel {
        border: 1px solid #dce6f7;
        border-radius: 12px;
        background: #fbfdff;
        padding: 0.75rem;
        display: grid;
        gap: 0.65rem;
    }

    .section-head {
        display: flex;
        justify-content: space-between;
        gap: 0.6rem;
        align-items: center;
        flex-wrap: wrap;
    }

    h2 {
        margin: 0;
        font-size: 1rem;
        color: #1f365b;
    }

    .subtle {
        color: #6b7280;
        margin: 0;
        font-size: 0.9rem;
    }

    .data-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 0.55rem;
    }

    .data-list li {
        border: 1px solid #dce6f7;
        border-radius: 10px;
        padding: 0.65rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.6rem;
        flex-wrap: wrap;
        background: #ffffff;
    }

    .identity {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
        align-items: baseline;
    }

    button {
        border: 1px solid #1f66d2;
        border-radius: 999px;
        background: #1f66d2;
        color: #fff;
        font-weight: 600;
        padding: 0.4rem 0.85rem;
        cursor: pointer;
    }

    button:hover {
        background: #1b57b3;
        border-color: #1b57b3;
    }

    button:disabled {
        cursor: not-allowed;
        opacity: 0.55;
    }

    .danger {
        background: #b42323;
        border-color: #b42323;
    }

    .danger:hover {
        background: #921f1f;
        border-color: #921f1f;
    }

    @media (max-width: 960px) {
        .split-layout {
            grid-template-columns: 1fr;
        }
    }
</style>
