---
import Layout from "../../../../layouts/Layout.astro";
import HospitalSubpageHeader from "../../../../components/admin/HospitalSubpageHeader.astro";
import { fetchAdminJson } from "../../../../utils/admin-api";

const API_URL = import.meta.env.API_URL ?? "http://localhost:8080";
const token = Astro.locals.authToken ?? null;
const slug = String(Astro.params.slug ?? "").trim();

type Hospital = {
    id: number;
    name: string;
    slug: string;
    is_active: boolean;
    created_at: string;
};

type HospitalInvite = {
    id: number;
    hospital_id: number;
    invite_role: string;
    created_by_clerk_id: string;
    expires_at: string;
    consumed_at: string | null;
    consumed_by_clerk_id?: string;
    created_at: string;
};

const fallbackInvites: HospitalInvite[] = [];
const fallbackHospitals: Hospital[] = [];

let createdInviteLink = "";
let createError = "";

const hospitalsResult = await fetchAdminJson(token, "/admin/hospitals", fallbackHospitals);
if (hospitalsResult.unauthorized) {
    return Astro.redirect("/");
}
const hospital = hospitalsResult.data.find((entry) => entry.slug === slug);
const hospitalLabel = hospital?.name ?? slug;

if (Astro.request.method === "POST") {
    if (!token) {
        return Astro.redirect("/");
    }

    const formData = await Astro.request.formData();
    const expiresInHours = Number(formData.get("expires_in_hours") ?? "72");

    const response = await fetch(`${API_URL}/admin/hospitals/${encodeURIComponent(slug)}/invites`, {
        method: "POST",
        headers: {
            Authorization: `Bearer ${token}`,
            "Content-Type": "application/json",
        },
        body: JSON.stringify({
            expires_in_hours: Number.isFinite(expiresInHours) ? expiresInHours : 72,
        }),
    }).catch(() => null);

    if (response?.ok) {
        const payload = (await response.json()) as {
            invite_path: string;
        };
        createdInviteLink = new URL(payload.invite_path, Astro.url.origin).toString();
    } else if (response?.status === 401 || response?.status === 403) {
        return Astro.redirect("/");
    } else {
        createError = "Failed to generate invite.";
    }
}

const invitesResult = await fetchAdminJson(
    token,
    `/admin/hospitals/${encodeURIComponent(slug)}/invites`,
    fallbackInvites,
);
if (invitesResult.unauthorized) {
    return Astro.redirect("/");
}

const invites = invitesResult.data;
---

<Layout title="Hospital Invites">
    <section class="panel">
        <HospitalSubpageHeader slug={slug} label={hospitalLabel} activeTab="invites" />

        <form method="post" class="invite-form" data-pending-label="Creating...">
            <label>
                Expires in (hours)
                <input name="expires_in_hours" type="number" min="1" max="720" value="72" />
            </label>
            <button type="submit">Create Invite Link</button>
        </form>

        {
            createdInviteLink && (
                <div class="invite-link-card" role="status">
                    <p class="invite-link-title">New invite link</p>
                    <div class="invite-link-row">
                        <input id="created-invite-link" value={createdInviteLink} readonly class="invite-link-input" />
                        <button type="button" class="copy-button" data-copy-target="created-invite-link">
                            Copy link
                        </button>
                    </div>
                </div>
            )
        }
        {createError && (
            <p class="error" role="alert">
                {createError}
            </p>
        )}

        {invites.length === 0 ? (
            <p class="empty-state">No invite links yet.</p>
        ) : (
            <ul class="invite-list">
                {
                    invites.map((invite) => (
                        <li>
                            <span>#{invite.id}</span>
                            <span>expires {new Date(invite.expires_at).toLocaleString()}</span>
                            {invite.consumed_at ? (
                                <span class="consumed">used</span>
                            ) : (
                                <span class="fresh">available</span>
                            )}
                        </li>
                    ))
                }
            </ul>
        )}
    </section>
</Layout>

<script is:inline>
    (() => {
        const pendingForms = document.querySelectorAll("form[data-pending-label]");
        for (const form of pendingForms) {
            form.addEventListener("submit", (event) => {
                const submitter = event.submitter instanceof HTMLElement ? event.submitter : null;
                const button =
                    submitter?.tagName === "BUTTON"
                        ? submitter
                        : form.querySelector("button[type='submit']");
                if (!button || button.disabled) {
                    return;
                }

                const pendingLabel = form.getAttribute("data-pending-label") ?? "Saving...";
                button.setAttribute("aria-busy", "true");
                button.textContent = pendingLabel;
                button.disabled = true;
            });
        }

        const copyButtons = document.querySelectorAll("button[data-copy-target]");
        for (const button of copyButtons) {
            button.addEventListener("click", async () => {
                const targetID = button.getAttribute("data-copy-target");
                if (!targetID) {
                    return;
                }
                const target = document.getElementById(targetID);
                if (!(target instanceof HTMLInputElement)) {
                    return;
                }

                const text = target.value;
                try {
                    await navigator.clipboard.writeText(text);
                    button.textContent = "Copied";
                } catch {
                    target.select();
                    button.textContent = "Press Ctrl/Cmd+C";
                    return;
                }
                window.setTimeout(() => {
                    button.textContent = "Copy link";
                }, 1400);
            });
        }
    })();
</script>

<style>
    .panel {
        background: #ffffff;
        border: 1px solid #dce6f7;
        border-radius: 16px;
        padding: clamp(1rem, 2.5vw, 1.5rem);
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    }

    .invite-form {
        margin-top: 0.9rem;
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
        align-items: end;
    }

    .invite-form label {
        display: grid;
        gap: 0.3rem;
    }

    .invite-form input {
        border: 1px solid #c9d8f2;
        border-radius: 9px;
        padding: 0.55rem 0.65rem;
        width: 10rem;
    }

    .invite-form button {
        border: none;
        border-radius: 999px;
        background: #1f66d2;
        color: #fff;
        font-weight: 600;
        padding: 0.45rem 0.9rem;
        cursor: pointer;
    }

    .invite-link-card {
        margin-top: 0.75rem;
        background: #f0f7ff;
        border: 1px solid #d4e6fb;
        padding: 0.6rem;
        border-radius: 8px;
        display: grid;
        gap: 0.45rem;
    }

    .invite-link-title {
        margin: 0;
        font-size: 0.88rem;
        color: #365479;
        font-weight: 600;
    }

    .invite-link-row {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .invite-link-input {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.86rem;
        border: 1px solid #c5d6f2;
        border-radius: 8px;
        padding: 0.5rem 0.55rem;
        flex: 1 1 22rem;
        min-width: 0;
        overflow-wrap: anywhere;
        color: #1f365b;
        background: #ffffff;
    }

    .copy-button {
        border: 1px solid #b8cdf0;
        border-radius: 999px;
        background: #ffffff;
        color: #1f4f95;
        font-weight: 600;
        padding: 0.4rem 0.8rem;
        cursor: pointer;
    }

    .error {
        color: #991b1b;
    }

    .empty-state {
        margin-top: 1rem;
        color: #6b7280;
    }

    .invite-list {
        list-style: none;
        margin: 1rem 0 0;
        padding: 0;
        display: grid;
        gap: 0.5rem;
    }

    .invite-list li {
        border: 1px solid #dce6f7;
        border-radius: 10px;
        padding: 0.65rem 0.75rem;
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        align-items: center;
    }

    .fresh {
        color: #166534;
        font-weight: 600;
    }

    .consumed {
        color: #991b1b;
        font-weight: 600;
    }
</style>
