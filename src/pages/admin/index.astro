---
import Layout from "../../layouts/Layout.astro";
import { probeAdminAccess } from "../../utils/admin-api";

const token = Astro.locals.authToken;
const canAccess = await probeAdminAccess(token);

if (!canAccess) {
    return Astro.redirect("/");
}
---

<Layout title="Admin">
    <section class="panel">
        <p class="eyebrow">Admin</p>
        <h1>Overview</h1>
        <p>Choose an area from the sidebar or use the shortcuts below.</p>

        <div class="quick-grid">
            <a class="quick-card" href="/admin/health">
                <h2>Health</h2>
                <p>Check backend and database availability.</p>
            </a>
            <a class="quick-card" href="/admin/users">
                <h2>Users</h2>
                <p>Review user identities, roles, and active status.</p>
            </a>
        </div>
    </section>
</Layout>

<style>
    .panel {
        background: #ffffff;
        border: 1px solid #dce6f7;
        border-radius: 16px;
        padding: clamp(1rem, 2.5vw, 1.5rem);
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    }

    .eyebrow {
        margin: 0;
        color: #2f76df;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    h1 {
        margin: 0 0 0.5rem;
        font-size: clamp(1.25rem, 3vw, 1.6rem);
        line-height: 1.25;
    }

    p {
        margin: 0.4rem 0;
    }

    .quick-grid {
        margin-top: 0.9rem;
        display: grid;
        gap: 0.75rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .quick-card {
        display: block;
        text-decoration: none;
        padding: 0.85rem 0.9rem;
        border: 1px solid #d6e2f7;
        border-radius: 12px;
        background: #f8fbff;
        color: #1f365b;
        transition:
            background-color 120ms ease,
            border-color 120ms ease;
    }

    .quick-card h2 {
        margin: 0;
        font-size: 1rem;
        line-height: 1.25;
    }

    .quick-card p {
        margin-top: 0.35rem;
        color: #516178;
        font-size: 0.93rem;
    }

    .quick-card:hover {
        background: #eef4ff;
        border-color: #c6d8f6;
    }

    @media (max-width: 720px) {
        .quick-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
