---
import Layout from "../../layouts/Layout.astro";
import { probeAdminAccess } from "../../utils/admin-api";

const token = Astro.locals.authToken;
const canAccess = await probeAdminAccess(token);

if (!canAccess) {
    return Astro.redirect("/");
}
---

<Layout title="Admin">
    <section class="panel">
        <h1>Admin</h1>
        <p>Manage privileged resources.</p>

        <nav class="admin-tabs" aria-label="Admin tabs">
            <a class="tab-link" href="/admin/health">Health</a>
            <a class="tab-link" href="/admin/users">Users</a>
        </nav>
    </section>
</Layout>

<style>
    .panel {
        background: #ffffff;
        border: 1px solid #dce6f7;
        border-radius: 16px;
        padding: clamp(1rem, 2.5vw, 1.5rem);
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    }

    h1 {
        margin: 0 0 0.5rem;
        font-size: clamp(1.25rem, 3vw, 1.6rem);
        line-height: 1.25;
    }

    p {
        margin: 0.4rem 0;
    }

    .admin-tabs {
        margin-top: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.35rem;
        width: fit-content;
        padding: 0.3rem;
        border: 1px solid #c9d9f6;
        border-radius: 999px;
        background: #f3f7ff;
    }

    .tab-link {
        display: inline-block;
        text-decoration: none;
        color: #27436f;
        border: 1px solid transparent;
        border-radius: 999px;
        padding: 0.4rem 0.8rem;
        font-weight: 600;
        transition:
            background-color 120ms ease,
            color 120ms ease,
            border-color 120ms ease;
    }

    .tab-link:hover {
        background: #e7efff;
        border-color: #c4d5f5;
        color: #1d3b66;
    }
</style>
