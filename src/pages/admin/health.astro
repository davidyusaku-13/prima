---
import Layout from "../../layouts/Layout.astro";
import { fetchAdminJsonWithStatus } from "../../utils/admin-api";

const token = Astro.locals.authToken;
const API_URL = Astro.locals.apiUrl;

type HealthComponentSnapshot = {
    name: string;
    status: string;
    latency_ms: number;
    checked_at: string;
    last_success_at: string;
    error: string;
};

type AdminHealthPayload = {
    status: string;
    summary: string;
    db: string;
    started_at: string;
    checked_at: string;
    uptime_seconds: number;
    version?: string;
    components: HealthComponentSnapshot[];
};

const fallbackHealth: AdminHealthPayload = {
    status: "down",
    summary: "Health data is unavailable.",
    db: "down",
    started_at: "",
    checked_at: "",
    uptime_seconds: 0,
    version: "",
    components: [],
};
const healthResult = await fetchAdminJsonWithStatus(token, "/admin/health", fallbackHealth, API_URL);

if (healthResult.unauthorized) {
    return Astro.redirect("/");
}

const health = healthResult.data;

type StatusViewModel = {
    label: string;
    tone: "ok" | "warning" | "danger";
    icon: string;
};

function getStatusViewModel(status: string): StatusViewModel {
    switch (status.toLowerCase()) {
        case "ok":
        case "up":
            return { label: "Healthy", tone: "ok", icon: "fa-circle-check" };
        case "degraded":
            return { label: "Degraded", tone: "warning", icon: "fa-triangle-exclamation" };
        case "down":
            return { label: "Down", tone: "danger", icon: "fa-circle-xmark" };
        default:
            return { label: status || "Unknown", tone: "warning", icon: "fa-circle-question" };
    }
}

function formatUptime(totalSeconds: number): string {
    const safeSeconds = Math.max(0, Math.floor(totalSeconds));
    const days = Math.floor(safeSeconds / 86400);
    const hours = Math.floor((safeSeconds % 86400) / 3600);
    const minutes = Math.floor((safeSeconds % 3600) / 60);
    const seconds = safeSeconds % 60;

    const parts: string[] = [];
    if (days > 0) parts.push(`${days}d`);
    if (hours > 0 || days > 0) parts.push(`${hours}h`);
    if (minutes > 0 || hours > 0 || days > 0) parts.push(`${minutes}m`);
    parts.push(`${seconds}s`);

    return parts.join(" ");
}

function formatTimestamp(value: string): string {
    if (!value) {
        return "-";
    }

    const date = new Date(value);
    if (Number.isNaN(date.getTime())) {
        return value;
    }

    return date.toLocaleString();
}

function formatLatency(latencyMs: number): string {
    if (!Number.isFinite(latencyMs) || latencyMs < 0) {
        return "-";
    }
    return `${Math.round(latencyMs)} ms`;
}

const backendStatus = getStatusViewModel(health.status);
const dbStatus = getStatusViewModel(health.db);
const statusSummary =
    health.summary?.trim() ||
    (health.status.toLowerCase() === "ok"
        ? "All monitored components are healthy."
        : "One or more components are degraded.");

const backendCheckedAt = health.checked_at?.trim() ? health.checked_at : new Date().toISOString();
const backendComponentStatus =
    healthResult.httpStatus === 0 ? "down" : healthResult.ok ? "up" : "degraded";
const backendComponentError =
    healthResult.transportError ||
    (!healthResult.ok ? `Health endpoint returned HTTP ${healthResult.httpStatus}.` : "");
const backendComponent: HealthComponentSnapshot = {
    name: "backend",
    status: backendComponentStatus,
    latency_ms: healthResult.latencyMs,
    checked_at: backendCheckedAt,
    last_success_at: healthResult.ok ? backendCheckedAt : "",
    error: backendComponentError,
};
const componentRows = [
    backendComponent,
    ...health.components.filter((component) => component.name.trim().toLowerCase() !== "backend"),
];
---

<Layout title="Admin Health">
    <section class="health-shell">
        <header class="panel header-panel">
            <p class="eyebrow">Admin</p>
            <div class="title-row">
                <h1>System Health</h1>
                <span class:list={["status-badge", `status-${backendStatus.tone}`]}>
                    <i class:list={["fa-solid", backendStatus.icon]} aria-hidden="true"></i>
                    {backendStatus.label}
                </span>
            </div>

            <p class="summary" role="status" aria-live="polite">{statusSummary}</p>
            {
                !healthResult.ok && (
                    <p class="degraded-note" role="status" aria-live="polite">
                        Health endpoint returned HTTP {healthResult.httpStatus}. Showing last response body.
                    </p>
                )
            }

            <div class="meta-grid">
                <p>Last checked: <strong>{formatTimestamp(health.checked_at)}</strong></p>
                <p>Started at: <strong>{formatTimestamp(health.started_at)}</strong></p>
                {health.version && <p>Version: <strong>{health.version}</strong></p>}
            </div>
        </header>

        <div class="metric-grid">
            <article class="panel metric-card">
                <p class="metric-label">Backend Status</p>
                <p class="metric-value">
                    <span class:list={["status-badge", `status-${backendStatus.tone}`]}>
                        <i class:list={["fa-solid", backendStatus.icon]} aria-hidden="true"></i>
                        {backendStatus.label}
                    </span>
                </p>
            </article>

            <article class="panel metric-card">
                <p class="metric-label">Database Status</p>
                <p class="metric-value">
                    <span class:list={["status-badge", `status-${dbStatus.tone}`]}>
                        <i class:list={["fa-solid", dbStatus.icon]} aria-hidden="true"></i>
                        {dbStatus.label}
                    </span>
                </p>
            </article>

            <article class="panel metric-card">
                <p class="metric-label">Uptime</p>
                <p class="metric-value">{formatUptime(health.uptime_seconds)}</p>
            </article>
        </div>

        <section class="panel">
            <div class="component-header">
                <h2>Component Checks</h2>
                <p>Detailed probe diagnostics for monitored dependencies.</p>
            </div>

            {
                componentRows.length === 0 ? (
                    <p class="empty-state" role="status">No component diagnostics are currently available.</p>
                ) : (
                    <div class="table-scroll">
                        <table class="health-table">
                            <thead>
                                <tr>
                                    <th scope="col">Component</th>
                                    <th scope="col">Status</th>
                                    <th scope="col">Latency</th>
                                    <th scope="col">Last Success</th>
                                    <th scope="col">Checked At</th>
                                    <th scope="col">Error</th>
                                </tr>
                            </thead>
                            <tbody>
                                {
                                    componentRows.map((component) => {
                                        const componentStatus = getStatusViewModel(component.status);
                                        return (
                                            <tr>
                                                <th scope="row">{component.name}</th>
                                                <td>
                                                    <span
                                                        class:list={[
                                                            "status-badge",
                                                            `status-${componentStatus.tone}`,
                                                        ]}
                                                    >
                                                        <i
                                                            class:list={[
                                                                "fa-solid",
                                                                componentStatus.icon,
                                                            ]}
                                                            aria-hidden="true"
                                                        ></i>
                                                        {componentStatus.label}
                                                    </span>
                                                </td>
                                                <td>{formatLatency(component.latency_ms)}</td>
                                                <td>{formatTimestamp(component.last_success_at)}</td>
                                                <td>{formatTimestamp(component.checked_at)}</td>
                                                <td>{component.error || "None"}</td>
                                            </tr>
                                        );
                                    })
                                }
                            </tbody>
                        </table>
                    </div>
                )
            }
        </section>
    </section>
</Layout>

<style>
    .health-shell {
        display: grid;
        gap: 1rem;
    }

    .panel {
        background: #ffffff;
        border: 1px solid #dce6f7;
        border-radius: 16px;
        padding: clamp(1rem, 2.5vw, 1.4rem);
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    }

    .header-panel {
        display: grid;
        gap: 0.65rem;
    }

    .eyebrow {
        margin: 0;
        color: #2f76df;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    .title-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.55rem;
    }

    h1 {
        margin: 0;
        font-size: clamp(1.3rem, 3vw, 1.75rem);
        line-height: 1.25;
        color: #102644;
    }

    .summary {
        margin: 0;
        color: #374151;
    }

    .degraded-note {
        margin: 0;
        color: #9a3412;
        font-size: 0.93rem;
    }

    .meta-grid {
        display: grid;
        gap: 0.45rem;
        margin-top: 0.1rem;
        color: #415166;
    }

    .meta-grid p {
        margin: 0;
    }

    .metric-grid {
        display: grid;
        gap: 0.9rem;
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .metric-card {
        display: grid;
        gap: 0.4rem;
    }

    .metric-label {
        margin: 0;
        color: #516178;
        font-size: 0.88rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-weight: 700;
    }

    .metric-value {
        margin: 0;
        color: #11233d;
        font-size: 1.15rem;
        font-weight: 700;
    }

    .component-header {
        margin-bottom: 0.8rem;
    }

    h2 {
        margin: 0;
        font-size: 1.08rem;
        color: #102644;
    }

    .component-header p {
        margin: 0.35rem 0 0;
        color: #516178;
        font-size: 0.93rem;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.42rem;
        border-radius: 999px;
        border: 1px solid transparent;
        padding: 0.26rem 0.62rem;
        font-size: 0.85rem;
        font-weight: 700;
        line-height: 1;
        white-space: nowrap;
    }

    .status-ok {
        background: #eaf8ef;
        color: #14532d;
        border-color: #b4e2c3;
    }

    .status-warning {
        background: #fff7e8;
        color: #9a3412;
        border-color: #f8d9a7;
    }

    .status-danger {
        background: #feeff1;
        color: #9f1239;
        border-color: #f7c7d2;
    }

    .table-scroll {
        overflow-x: auto;
    }

    .health-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 740px;
    }

    .health-table th,
    .health-table td {
        padding: 0.68rem 0.58rem;
        border-bottom: 1px solid #e4ecf8;
        text-align: left;
        color: #23364f;
        vertical-align: top;
    }

    .health-table thead th {
        color: #516178;
        font-size: 0.83rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .empty-state {
        margin: 0;
        color: #516178;
    }

    @media (max-width: 960px) {
        .metric-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 680px) {
        .metric-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
