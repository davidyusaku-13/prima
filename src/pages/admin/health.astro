---
import Layout from "../../layouts/Layout.astro";
import { fetchAdminJson } from "../../utils/admin-api";

const token = Astro.locals.authToken;

const fallbackHealth = { status: "down", db: "down" };
const healthResult = await fetchAdminJson(token, "/admin/health", fallbackHealth);

if (healthResult.unauthorized) {
    return Astro.redirect("/");
}

const health = healthResult.data;
---

<Layout title="Admin Health">
    <section class="panel">
        <h1>Admin</h1>
        <nav class="admin-tabs" aria-label="Admin tabs">
            <a class="tab-link is-active" href="/admin/health">Health</a>
            <a class="tab-link" href="/admin/users">Users</a>
        </nav>

        <p class="status-line">Backend health: <strong>{health.status}</strong></p>
        <p class="status-line">DB health: <strong>{health.db}</strong></p>
    </section>
</Layout>

<style>
    .panel {
        background: #ffffff;
        border: 1px solid #dce6f7;
        border-radius: 16px;
        padding: clamp(1rem, 2.5vw, 1.5rem);
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    }

    h1 {
        margin: 0 0 0.5rem;
        font-size: clamp(1.25rem, 3vw, 1.6rem);
        line-height: 1.25;
    }

    .admin-tabs {
        margin: 0 0 0.95rem;
        display: flex;
        align-items: center;
        gap: 0.35rem;
        width: fit-content;
        padding: 0.3rem;
        border: 1px solid #c9d9f6;
        border-radius: 999px;
        background: #f3f7ff;
    }

    .tab-link {
        display: inline-block;
        text-decoration: none;
        color: #27436f;
        border: 1px solid transparent;
        border-radius: 999px;
        padding: 0.4rem 0.8rem;
        font-weight: 600;
        transition:
            background-color 120ms ease,
            color 120ms ease,
            border-color 120ms ease;
    }

    .tab-link:hover {
        background: #e7efff;
        border-color: #c4d5f5;
        color: #1d3b66;
    }

    .tab-link.is-active {
        background: #ffffff;
        border-color: #bfd3f6;
        color: #1f3f6f;
    }

    .status-line {
        margin: 0.4rem 0;
        color: #374151;
    }
</style>
