---
import Layout from "../../layouts/Layout.astro";
import { fetchAdminJson } from "../../utils/admin-api";

const token = Astro.locals.authToken;

type AdminHealthPayload = {
    status: string;
    db: string;
    started_at: string;
    checked_at: string;
    uptime_seconds: number;
};

const fallbackHealth: AdminHealthPayload = {
    status: "down",
    db: "down",
    started_at: "",
    checked_at: "",
    uptime_seconds: 0,
};
const healthResult = await fetchAdminJson(token, "/admin/health", fallbackHealth);

if (healthResult.unauthorized) {
    return Astro.redirect("/");
}

const health = healthResult.data;

function formatUptime(totalSeconds: number): string {
    const safeSeconds = Math.max(0, Math.floor(totalSeconds));
    const days = Math.floor(safeSeconds / 86400);
    const hours = Math.floor((safeSeconds % 86400) / 3600);
    const minutes = Math.floor((safeSeconds % 3600) / 60);
    const seconds = safeSeconds % 60;

    const parts: string[] = [];
    if (days > 0) parts.push(`${days}d`);
    if (hours > 0 || days > 0) parts.push(`${hours}h`);
    if (minutes > 0 || hours > 0 || days > 0) parts.push(`${minutes}m`);
    parts.push(`${seconds}s`);

    return parts.join(" ");
}

function formatTimestamp(value: string): string {
    if (!value) {
        return "-";
    }

    const date = new Date(value);
    if (Number.isNaN(date.getTime())) {
        return value;
    }

    return date.toLocaleString();
}
---

<Layout title="Admin Health">
    <section class="panel">
        <p class="eyebrow">Admin</p>
        <h1>Health</h1>

        <p class="status-line">Backend health: <strong>{health.status}</strong></p>
        <p class="status-line">DB health: <strong>{health.db}</strong></p>
        <p class="status-line">Uptime: <strong>{formatUptime(health.uptime_seconds)}</strong></p>
        <p class="status-line">Started at: <strong>{formatTimestamp(health.started_at)}</strong></p>
        <p class="status-line">Last checked: <strong>{formatTimestamp(health.checked_at)}</strong></p>
    </section>
</Layout>

<style>
    .panel {
        background: #ffffff;
        border: 1px solid #dce6f7;
        border-radius: 16px;
        padding: clamp(1rem, 2.5vw, 1.5rem);
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    }

    .eyebrow {
        margin: 0;
        color: #2f76df;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    h1 {
        margin: 0 0 0.5rem;
        font-size: clamp(1.25rem, 3vw, 1.6rem);
        line-height: 1.25;
    }

    .status-line {
        margin: 0.4rem 0;
        color: #374151;
    }
</style>
