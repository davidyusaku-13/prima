---
import {
    SignedIn,
    SignedOut,
    UserButton,
    SignInButton,
    SignUpButton,
} from "@clerk/astro/components";

import "@/styles/global.css";

const isAdminRoute =
    Astro.url.pathname === "/admin" || Astro.url.pathname.startsWith("/admin/");

const pathname = Astro.url.pathname;
const isHomeRoute = pathname === "/";
const isFullWidthRoute = isHomeRoute || isAdminRoute;
const navLinks = [
    { href: "/", label: "Beranda", icon: "fa-house" },
    { href: "/pasien", label: "Pasien", icon: "fa-hospital-user" },
    { href: "/berita", label: "Berita", icon: "fa-newspaper" },
    { href: "/video-edukasi", label: "Video Edukasi", icon: "fa-circle-play" },
];

const isNavActive = (href: string) =>
    href === "/"
        ? pathname === "/"
        : pathname === href || pathname.startsWith(`${href}/`);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <script
            is:inline
            src="https://kit.fontawesome.com/ec712a3d01.js"
            crossorigin="anonymous"
        ></script>
        <script is:inline>
            (() => {
                try {
                    if (localStorage.getItem("prima_sidebar_state") === "collapsed") {
                        document.documentElement.classList.add("sidebar-collapsed");
                    }
                } catch {}
            })();
        </script>
        <title>Astro Basics</title>
    </head>
    <body>
        <div class="app-layout">
            <aside class="sidebar">
                <div class="sidebar-header">
                    <a class="brand" href="/" aria-label="Go to home page">
                        <span class="brand-logo" aria-hidden="true">
                            <i class="fa-solid fa-heart-pulse"></i>
                        </span>
                        <span class="brand-text">PrimaCare</span>
                    </a>
                    <button
                        id="sidebar-toggle"
                        class="sidebar-toggle"
                        type="button"
                        aria-label="Collapse sidebar"
                        aria-expanded="true"
                    >
                        <i class="fa-solid fa-angles-left toggle-icon-expanded" aria-hidden="true"></i>
                        <i class="fa-solid fa-angles-right toggle-icon-collapsed" aria-hidden="true"></i>
                    </button>
                </div>

                <nav class="main-nav" aria-label="Main navigation">
                    {
                        navLinks.map((item) => (
                            <a
                                href={item.href}
                                class:list={["nav-link", { "is-active": isNavActive(item.href) }]}
                                title={item.label}
                                aria-label={item.label}
                            >
                                <i class={`fa-solid ${item.icon} nav-link-icon`} aria-hidden="true"></i>
                                <span class="nav-link-text">{item.label}</span>
                            </a>
                        ))
                    }

                    <button
                        id="admin-popover-trigger"
                        class="admin-popover-trigger nav-link"
                        type="button"
                        aria-haspopup="menu"
                        aria-expanded="false"
                        title="Admin"
                    >
                        <i class="fa-solid fa-user-shield nav-link-icon" aria-hidden="true"></i>
                        <span class="nav-link-text">Admin</span>
                    </button>

                    <div id="admin-popover" class="admin-popover" popover>
                        <a
                            href="/admin"
                            class:list={[
                                "admin-popover-link",
                                { "is-active": pathname === "/admin" },
                            ]}
                            aria-current={pathname === "/admin" ? "page" : undefined}
                        >
                            <i class="fa-solid fa-gauge-high sub-nav-icon" aria-hidden="true"></i>
                            <span>Overview</span>
                        </a>
                        <a
                            href="/admin/health"
                            class:list={[
                                "admin-popover-link",
                                { "is-active": pathname === "/admin/health" },
                            ]}
                            aria-current={pathname === "/admin/health" ? "page" : undefined}
                        >
                            <i class="fa-solid fa-heart-pulse sub-nav-icon" aria-hidden="true"></i>
                            <span>Health</span>
                        </a>
                        <a
                            href="/admin/users"
                            class:list={[
                                "admin-popover-link",
                                { "is-active": pathname === "/admin/users" },
                            ]}
                            aria-current={pathname === "/admin/users" ? "page" : undefined}
                        >
                            <i class="fa-solid fa-users sub-nav-icon" aria-hidden="true"></i>
                            <span>Users</span>
                        </a>
                    </div>

                    <details id="admin-nav-group" class="nav-group" open={isAdminRoute}>
                        <summary
                            class:list={[
                                "nav-link",
                                "nav-group-summary",
                                { "is-active": isAdminRoute },
                            ]}
                            title="Admin"
                        >
                            <span class="nav-group-label">
                                <i class="fa-solid fa-user-shield nav-link-icon" aria-hidden="true"></i>
                                <span class="nav-link-text">Admin</span>
                            </span>
                            <i class="fa-solid fa-chevron-down nav-group-chevron" aria-hidden="true"></i>
                        </summary>

                        <div class="sub-nav" role="list" aria-label="Admin navigation">
                            <a
                                href="/admin"
                                class:list={[
                                    "sub-nav-link",
                                    { "is-active": pathname === "/admin" },
                                ]}
                                aria-current={pathname === "/admin" ? "page" : undefined}
                                title="Overview"
                                aria-label="Overview"
                            >
                                <i class="fa-solid fa-gauge-high sub-nav-icon" aria-hidden="true"></i>
                                <span class="sub-nav-text">Overview</span>
                            </a>
                            <a
                                href="/admin/health"
                                class:list={[
                                    "sub-nav-link",
                                    { "is-active": pathname === "/admin/health" },
                                ]}
                                aria-current={pathname === "/admin/health" ? "page" : undefined}
                                title="Health"
                                aria-label="Health"
                            >
                                <i class="fa-solid fa-heart-pulse sub-nav-icon" aria-hidden="true"></i>
                                <span class="sub-nav-text">Health</span>
                            </a>
                            <a
                                href="/admin/users"
                                class:list={[
                                    "sub-nav-link",
                                    { "is-active": pathname === "/admin/users" },
                                ]}
                                aria-current={pathname === "/admin/users" ? "page" : undefined}
                                title="Users"
                                aria-label="Users"
                            >
                                <i class="fa-solid fa-users sub-nav-icon" aria-hidden="true"></i>
                                <span class="sub-nav-text">Users</span>
                            </a>
                        </div>
                    </details>
                </nav>

                <div class="sidebar-footer">
                    <div class="auth-actions">
                        {
                            /* Show the sign-in and sign-up buttons when the user is signed out */
                        }
                        <SignedOut>
                            <SignInButton
                                mode="modal"
                                class="auth-btn auth-btn-secondary"
                                set:text={"Login"}
                            />
                            <SignUpButton
                                mode="modal"
                                class="auth-btn auth-btn-primary"
                                set:text={"Create account"}
                            />
                        </SignedOut>
                        {/* Show the user button when the user is signed in */}
                        <SignedIn>
                            <UserButton />
                        </SignedIn>
                    </div>
                </div>

            </aside>
            <main
                class:list={[
                    "page-shell",
                    {
                        "page-shell-wide": isAdminRoute,
                        "page-shell-full": isFullWidthRoute,
                    },
                ]}
            >
                <slot />
            </main>
        </div>
        <script is:inline>
            (() => {
                const key = "prima_sidebar_state";
                const root = document.documentElement;
                const toggleButton = document.getElementById("sidebar-toggle");
                const adminPopoverTrigger = document.getElementById("admin-popover-trigger");
                const adminPopover = document.getElementById("admin-popover");

                if (!toggleButton) {
                    return;
                }

                const isDesktopCollapsed = () =>
                    root.classList.contains("sidebar-collapsed") && window.innerWidth > 760;

                const hideAdminPopover = () => {
                    if (
                        adminPopover &&
                        "hidePopover" in adminPopover &&
                        adminPopover.matches(":popover-open")
                    ) {
                        adminPopover.hidePopover();
                    }

                    if (adminPopoverTrigger) {
                        adminPopoverTrigger.setAttribute("aria-expanded", "false");
                    }
                };

                const placeAdminPopover = () => {
                    if (!adminPopover || !adminPopoverTrigger) {
                        return;
                    }

                    const triggerRect = adminPopoverTrigger.getBoundingClientRect();
                    const popoverWidth = 190;
                    const margin = 10;

                    let left = triggerRect.right + 10;
                    if (left + popoverWidth > window.innerWidth - margin) {
                        left = triggerRect.left - popoverWidth - 10;
                    }
                    left = Math.max(margin, left);

                    const top = Math.min(
                        window.innerHeight - 160,
                        Math.max(margin, triggerRect.top),
                    );

                    adminPopover.style.left = `${left}px`;
                    adminPopover.style.top = `${top}px`;
                };

                const syncButtonState = () => {
                    const collapsed = root.classList.contains("sidebar-collapsed");

                    if (!isDesktopCollapsed()) {
                        hideAdminPopover();
                    }

                    toggleButton.setAttribute("aria-expanded", String(!collapsed));
                    toggleButton.setAttribute(
                        "aria-label",
                        collapsed ? "Expand sidebar" : "Collapse sidebar",
                    );
                };

                syncButtonState();

                toggleButton.addEventListener("click", () => {
                    const collapsed = root.classList.toggle("sidebar-collapsed");
                    try {
                        localStorage.setItem(key, collapsed ? "collapsed" : "expanded");
                    } catch {}
                    syncButtonState();
                });

                if (
                    adminPopover &&
                    adminPopoverTrigger &&
                    "showPopover" in adminPopover &&
                    "hidePopover" in adminPopover
                ) {
                    adminPopoverTrigger.addEventListener("click", (event) => {
                        if (!isDesktopCollapsed()) {
                            return;
                        }

                        event.preventDefault();

                        if (adminPopover.matches(":popover-open")) {
                            hideAdminPopover();
                            return;
                        }

                        placeAdminPopover();
                        adminPopover.showPopover();
                        adminPopoverTrigger.setAttribute("aria-expanded", "true");
                    });

                    adminPopover.addEventListener("toggle", () => {
                        adminPopoverTrigger.setAttribute(
                            "aria-expanded",
                            adminPopover.matches(":popover-open") ? "true" : "false",
                        );
                    });

                    window.addEventListener("resize", () => {
                        if (!isDesktopCollapsed()) {
                            hideAdminPopover();
                            return;
                        }

                        if (adminPopover.matches(":popover-open")) {
                            placeAdminPopover();
                        }
                    });
                }
            })();
        </script>
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        min-height: 100%;
        font-family: "Avenir Next", "Segoe UI", sans-serif;
        background: linear-gradient(180deg, #f6f8fc 0%, #eef4ff 100%);
        color: #1f2937;
    }

    .app-layout {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 260px minmax(0, 1fr);
        gap: 1rem;
        padding: 1rem;
        transition: grid-template-columns 260ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .sidebar {
        position: sticky;
        top: 1rem;
        align-self: start;
        min-height: calc(100vh - 2rem);
        display: flex;
        flex-direction: column;
        padding: 0.95rem;
        border: 1px solid #d7e3f7;
        border-radius: 1rem;
        background: rgba(255, 255, 255, 0.85);
        box-shadow: 0 10px 24px rgba(39, 67, 111, 0.08);
        backdrop-filter: blur(6px);
        overflow: visible;
        transition: padding 220ms ease;
    }

    .sidebar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
    }

    .sidebar-toggle {
        width: 2rem;
        height: 2rem;
        border: 1px solid #d0def6;
        border-radius: 0.6rem;
        background: #eef4ff;
        color: #365885;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition:
            right 220ms ease,
            width 220ms ease,
            height 220ms ease,
            transform 220ms ease,
            box-shadow 220ms ease,
            background-color 120ms ease,
            border-color 120ms ease;
        flex: none;
    }

    .sidebar-toggle:hover {
        background: #e2edff;
        border-color: #c3d6f7;
    }

    .toggle-icon-collapsed {
        display: none;
    }

    .brand {
        display: inline-grid;
        grid-template-columns: 2rem 1fr;
        align-items: center;
        gap: 0.55rem;
        text-decoration: none;
        color: #163560;
        white-space: nowrap;
        transition: grid-template-columns 220ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .brand-logo {
        width: 2rem;
        height: 2rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
        color: #ffffff;
        background: linear-gradient(135deg, #2f76df 0%, #255fc2 100%);
        box-shadow: 0 8px 16px rgba(37, 95, 194, 0.28);
    }

    .brand-text {
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.01em;
    }

    .brand-text,
    .nav-link-text,
    .sub-nav-text {
        white-space: nowrap;
        overflow: hidden;
        min-width: 0;
        opacity: 1;
        transition: opacity 180ms ease;
    }

    .main-nav {
        margin-top: 1rem;
        display: grid;
        gap: 0.35rem;
    }

    .nav-link {
        display: grid;
        grid-template-columns: 0.95rem 1fr;
        align-items: center;
        gap: 0.55rem;
        text-decoration: none;
        color: #27436f;
        font-weight: 600;
        border-radius: 0.7rem;
        padding: 0.55rem 0.7rem;
        width: 100%;
        transition:
            grid-template-columns 220ms cubic-bezier(0.22, 1, 0.36, 1),
            padding 220ms ease,
            background-color 120ms ease,
            color 120ms ease,
            border-color 120ms ease;
        border: 1px solid transparent;
    }

    .nav-link:hover {
        background: #e9f0fd;
        color: #1b3559;
        border-color: #d0def6;
    }

    .nav-link.is-active {
        background: #e4eefc;
        color: #12315c;
        border-color: #b8cdf0;
    }

    .nav-group {
        margin-top: 0.15rem;
    }

    .admin-popover-trigger {
        display: none;
    }

    .admin-popover {
        margin: 0;
        inset: auto;
        border: 1px solid #cfdcf5;
        border-radius: 0.75rem;
        background: #ffffff;
        box-shadow: 0 14px 30px rgba(24, 39, 72, 0.2);
        padding: 0.35rem;
        min-width: 180px;
    }

    .admin-popover::backdrop {
        background: transparent;
    }

    .admin-popover-link {
        display: inline-flex;
        width: 100%;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: #244870;
        border-radius: 0.55rem;
        border: 1px solid transparent;
        padding: 0.45rem 0.55rem;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .admin-popover-link:hover {
        background: #edf3fe;
        border-color: #d0def6;
        color: #153b66;
    }

    .admin-popover-link.is-active {
        background: #e5effd;
        border-color: #c4d8f7;
        color: #163662;
    }

    .nav-group-summary {
        cursor: pointer;
        list-style: none;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.6rem;
    }

    .nav-group-summary::-webkit-details-marker {
        display: none;
    }

    .nav-group-label {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
    }

    .nav-link-icon {
        width: 0.95rem;
        text-align: center;
        color: #4f6890;
    }

    .nav-group-chevron {
        font-size: 0.75rem;
        color: #5b7293;
        transition: transform 120ms ease;
    }

    .nav-group[open] .nav-group-chevron {
        transform: rotate(180deg);
    }

    .sub-nav {
        display: none;
        gap: 0.3rem;
        margin-top: 0.3rem;
        margin-left: 0.4rem;
        padding-left: 0.65rem;
        border-left: 2px solid #d9e5fa;
    }

    .nav-group[open] .sub-nav {
        display: grid;
    }

    .sub-nav-link {
        display: grid;
        grid-template-columns: 0.85rem 1fr;
        align-items: center;
        gap: 0.48rem;
        text-decoration: none;
        color: #35547f;
        font-size: 0.9rem;
        font-weight: 600;
        border-radius: 0.6rem;
        padding: 0.42rem 0.6rem;
        border: 1px solid transparent;
        transition:
            grid-template-columns 220ms cubic-bezier(0.22, 1, 0.36, 1),
            background-color 120ms ease,
            border-color 120ms ease,
            color 120ms ease;
    }

    .sub-nav-link:hover {
        background: #edf3fe;
        border-color: #d0def6;
        color: #1e3d69;
    }

    .sub-nav-link.is-active {
        background: #e5effd;
        border-color: #c4d8f7;
        color: #163662;
    }

    .sub-nav-icon {
        width: 0.85rem;
        text-align: center;
        color: #5d7395;
        font-size: 0.78rem;
    }

    :global(html.sidebar-collapsed) .app-layout {
        grid-template-columns: 84px minmax(0, 1fr);
    }

    :global(html.sidebar-collapsed) .sidebar {
        padding: 0.85rem 0.55rem;
    }

    :global(html.sidebar-collapsed) .sidebar-header {
        flex-direction: row;
        justify-content: center;
    }

    :global(html.sidebar-collapsed) .brand {
        grid-template-columns: 2rem 0fr;
        justify-content: center;
        width: 100%;
    }

    :global(html.sidebar-collapsed) .brand-text,
    :global(html.sidebar-collapsed) .nav-link-text,
    :global(html.sidebar-collapsed) .sub-nav-text {
        opacity: 0;
    }

    :global(html.sidebar-collapsed) .nav-link {
        grid-template-columns: 0.95rem 0fr;
        justify-content: center;
        padding: 0.55rem 0.45rem;
    }

    :global(html.sidebar-collapsed) .nav-group-summary {
        justify-content: center;
        padding: 0.55rem 0.45rem;
    }

    :global(html.sidebar-collapsed) .nav-group-label {
        justify-content: center;
    }

    :global(html.sidebar-collapsed) .nav-group {
        display: none;
    }

    :global(html.sidebar-collapsed) .admin-popover-trigger {
        display: grid;
        grid-template-columns: 0.95rem 0fr;
        justify-content: center;
        padding: 0.55rem 0.45rem;
    }

    :global(html.sidebar-collapsed) .sidebar-toggle {
        position: absolute;
        top: 1rem;
        right: -0.8rem;
        width: 1.7rem;
        height: 1.7rem;
        border-radius: 999px;
        border-color: #b7cdf3;
        background: #f2f7ff;
        box-shadow: 0 8px 16px rgba(30, 56, 99, 0.18);
        z-index: 3;
    }

    :global(html.sidebar-collapsed) .sidebar-footer {
        padding-top: 0.7rem;
    }

    :global(html.sidebar-collapsed) .auth-actions {
        justify-content: center;
    }

    :global(html.sidebar-collapsed) :global(.auth-btn) {
        display: none;
    }

    :global(html.sidebar-collapsed) .toggle-icon-expanded {
        display: none;
    }

    :global(html.sidebar-collapsed) .toggle-icon-collapsed {
        display: inline-block;
    }

    .sidebar-footer {
        margin-top: auto;
        padding-top: 1rem;
        border-top: 1px solid #dee7f8;
    }

    .auth-actions {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    @media (max-width: 940px) {
        .app-layout {
            grid-template-columns: 220px minmax(0, 1fr);
        }
    }

    @media (max-width: 760px) {
        .app-layout {
            grid-template-columns: 1fr;
            padding: 0.75rem;
        }

        .sidebar-toggle {
            display: none;
        }

        :global(html.sidebar-collapsed) .app-layout {
            grid-template-columns: 1fr;
        }

        :global(html.sidebar-collapsed) .sidebar {
            padding: 0.95rem;
        }

        :global(html.sidebar-collapsed) .sidebar-header {
            flex-direction: row;
        }

        :global(html.sidebar-collapsed) .brand {
            grid-template-columns: 2rem 1fr;
            justify-content: flex-start;
        }

        :global(html.sidebar-collapsed) .brand-text,
        :global(html.sidebar-collapsed) .nav-link-text,
        :global(html.sidebar-collapsed) .sub-nav-text {
            opacity: 1;
        }

        :global(html.sidebar-collapsed) .nav-link {
            grid-template-columns: 0.95rem 1fr;
            justify-content: start;
            padding: 0.55rem 0.7rem;
        }

        :global(html.sidebar-collapsed) .nav-group-summary {
            justify-content: flex-start;
            padding: 0.55rem 0.7rem;
        }

        :global(html.sidebar-collapsed) .nav-group-label {
            justify-content: flex-start;
        }

        :global(html.sidebar-collapsed) .nav-group {
            display: block;
        }

        :global(html.sidebar-collapsed) .admin-popover-trigger {
            display: none;
        }

        :global(html.sidebar-collapsed) .sub-nav {
            margin-left: 0.4rem;
            padding-left: 0.65rem;
            border-left: 2px solid #d9e5fa;
        }

        :global(html.sidebar-collapsed) .nav-group[open] .sub-nav {
            display: grid;
        }

        :global(html.sidebar-collapsed) :global(.auth-btn) {
            display: inline-flex;
        }

        .sidebar {
            position: static;
            min-height: auto;
        }

        .main-nav {
            width: 100%;
            margin-top: 0.85rem;
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .sidebar-footer {
            margin-top: 0.85rem;
            padding-top: 0.85rem;
        }
    }

    @media (max-width: 520px) {
        .main-nav {
            grid-template-columns: 1fr;
        }

        .auth-actions {
            width: 100%;
            justify-content: flex-start;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .app-layout,
        .sidebar,
        .sidebar-toggle,
        .brand,
        .nav-link,
        .sub-nav-link,
        .brand-text,
        .nav-link-text,
        .sub-nav-text {
            transition: none;
        }
    }

    :global([data-clerk-id^="clerk-user-button-"]) {
        width: 2.25rem;
        height: 2.25rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    :global([data-clerk-id^="clerk-user-button-"]:empty) {
        border-radius: 999px;
        background: linear-gradient(135deg, #e3ecff 0%, #d4e1fb 100%);
        box-shadow: inset 0 0 0 1px #c4d5f5;
        animation: clerk-user-button-pulse 900ms ease-in-out infinite alternate;
    }

    @keyframes clerk-user-button-pulse {
        from {
            opacity: 0.65;
        }

        to {
            opacity: 1;
        }
    }

    .auth-btn {
        border: 1px solid transparent;
        border-radius: 999px;
        padding: 0.55rem 0.95rem;
